# Cron del host para Balneario El Cóndor
# Instalar con: crontab -e (como el usuario que tiene permisos sobre el repo + docker)

# Backup diario 03:00 AM (incluye off-site rclone si RCLONE_REMOTE está set)
0 3 * * * /opt/balneario/ops/backup.sh >> /var/log/balneario-backup.log 2>&1

# Test de restore semanal (domingo 04:00) — verifica que el último backup
# off-site se restaura OK y tiene data esperada. Manda webhook si falla.
0 4 * * 0 /opt/balneario/ops/test-restore.sh >> /var/log/balneario-restore-test.log 2>&1

# Nota: el scheduler de Laravel (weather:sync, etc.) corre dentro del
# container 'scheduler' con php artisan schedule:work, no requiere cron del host.
