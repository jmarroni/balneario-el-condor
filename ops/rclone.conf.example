# Ejemplo de rclone.conf — copiar a ~/.config/rclone/rclone.conf y completar
# Configurar interactivamente con: rclone config
# Después de configurar, setear en app/.env.production:
#   RCLONE_REMOTE=balneario-encrypted:/

# ===== Backblaze B2 (recomendado: barato, S3-compatible) =====
[b2]
type = b2
account = APPLICATION_KEY_ID
key = APPLICATION_KEY
hard_delete = true

# ===== AWS S3 (alternativa) =====
[s3]
type = s3
provider = AWS
region = sa-east-1
access_key_id = AKIA...
secret_access_key = ...
storage_class = STANDARD_IA       # Infrequent Access — más barato

# ===== Cifrado encima del backend (recomendado) =====
# Las contraseñas las generás con: rclone config (modo interactivo, opción n=new remote, type=crypt)
[balneario-encrypted]
type = crypt
remote = b2:balneario-backups-bucket   # o s3:balneario-bucket
filename_encryption = standard
directory_name_encryption = true
password = OBSCURED_PASSWORD            # NO usar tu password en plain — rclone la "obscure"
password2 = OBSCURED_SALT
