# ===== App =====
APP_NAME="Balneario El Cóndor"
APP_ENV=production
APP_KEY=                         # generar con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://elcondor.gob.ar
APP_VERSION=v1.0.0
APP_DOMAIN=elcondor.gob.ar
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_TIMEZONE="America/Argentina/Buenos_Aires"

# ===== Database (interna, no se publica al host) =====
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=balneario_prod
DB_USERNAME=balneario
DB_PASSWORD=                     # secret

# MariaDB root + user (init container)
MYSQL_ROOT_PASSWORD=             # secret, distinto del DB_PASSWORD
MYSQL_DATABASE=balneario_prod
MYSQL_USER=balneario
MYSQL_PASSWORD=                  # secret = DB_PASSWORD

# Puerto host (no se usa en prod — db.ports = [] vacío)
DB_HOST_PORT=33061

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                  # secret obligatorio en prod
REDIS_HOST_PORT=63791            # no usado en prod
REDIS_CLIENT=phpredis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ===== Mail (Resend) =====
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="no-reply@elcondor.gob.ar"
MAIL_FROM_NAME="Balneario El Cóndor"
ADMIN_NOTIFICATION_EMAIL=turismo@elcondor.gob.ar
RESEND_KEY=                      # secret: re_xxxx desde dashboard.resend.com

# ===== Logging =====
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_STACK=daily,errorlog

# ===== Session =====
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.elcondor.gob.ar
SESSION_SAME_SITE=lax

# ===== Sanctum =====
SANCTUM_STATEFUL_DOMAINS=elcondor.gob.ar

# ===== nginx port (interno, no publicado) =====
APP_PORT=80

# ===== Sentry (opcional) =====
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Migration on boot =====
MIGRATE_ON_BOOT=false           # true solo en deploys con cambios de schema

# ===== Scribe docs en prod =====
SCRIBE_DOCS_ENABLED=false        # false por default; true requiere basic auth
SCRIBE_DOCS_BASIC_AUTH_USER=     # opcional
SCRIBE_DOCS_BASIC_AUTH_PASS=     # opcional

# ===== Backup (consumido por ops/backup.sh) =====
BACKUP_DIR=/var/backups/balneario
BACKUP_RETENTION_DAYS=14

# Off-site backup (opcional). Configurar rclone primero (ver ops/rclone.conf.example).
# Ejemplos: b2:balneario-backups, s3:balneario-bucket, balneario-encrypted:/
RCLONE_REMOTE=

# ===== Deploy webhook (Slack/Discord, opcional) =====
DEPLOY_WEBHOOK_URL=

# ===== Open-Meteo (sin key, no requiere secret) =====
# Las coords están hardcoded en SyncWeatherCommand: -41.05, -62.82

# ===== Vite =====
VITE_APP_NAME="${APP_NAME}"
